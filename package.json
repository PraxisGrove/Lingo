{
  "name": "lingo-translation",
  "description": "Open-source bilingual webpage translation extension.",
  "license": "AGPL-3.0-only",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "locales": "node scripts/generate-browser-locales.mjs",
    "browser:install": "playwright install chromium firefox",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "pnpm locales && wxt build",
    "build:firefox": "pnpm locales && wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "format": "biome check --write .",
    "check": "biome check .",
    "commitlint": "commitlint",
    "verify:commit": "pnpm lint && pnpm test && pnpm test:browser && pnpm compile && pnpm check && pnpm build && pnpm build:firefox && git diff --check",
    "prepare": "lefthook install",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@wxt-dev/storage": "^1.2.8",
    "i18next": "^26.3.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "4.1.10",
    "@wxt-dev/module-react": "^1.1.5",
    "happy-dom": "^20.10.6",
    "lefthook": "^2.1.10",
    "playwright": "^1.61.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wxt": "^0.20.27"
  }
}
